{
  "name": "paradigm-reboot-prober",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prepare": "cd .. && sh scripts/setup-submodules.sh",
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "generate:api": "swagger2openapi ../docs/swagger.json -o src/api/openapi3.json && openapi-typescript src/api/openapi3.json -o src/api/generated.d.ts"
  },
  "dependencies": {
    "@vueuse/core": "^12.5.0",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "echarts": "^5.6.0",
    "file-saver": "^2.0.5",
    "naive-ui": "^2.40.3",
    "pako": "^2.1.0",
    "pinia": "^2.3.0",
    "pinia-plugin-persistedstate": "^3.2.3",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^11.1.0",
    "vue-router": "^4.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "vue-demi"]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/file-saver": "^2.0.7",
    "@types/pako": "^2.0.4",
    "@vitejs/plugin-vue": "^5.2.0",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.13.0",
    "swagger2openapi": "^7.0.8",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.1.0",
    "vue-tsc": "^2.2.0"
  }
}
