server:
  port: ":8080"

database:
  # type: "sqlite"
  # dsn: "prober.db"
  type: "postgres"
  host: "localhost"
  port: 5432
  user: "postgres"
  password: "password"
  dbname: "prp"
  sslmode: "disable"

auth:
  secret_key: "your_secret_key_here"
  jwt_algorithm: "HS256"
  jwt_expiration: "24h"             # access token lifetime, e.g. "24h", "30m"
  bcrypt_cost: 10                   # bcrypt hashing cost (4-31)
  upload_token_length: 16           # bytes; hex output is 2x this value
  username_pattern: "^[A-Za-z][A-Za-z0-9_]{5,15}$"

pagination:
  default_page_size: 50
  max_page_size: 200

game:
  b35_limit: 35
  b15_limit: 15
