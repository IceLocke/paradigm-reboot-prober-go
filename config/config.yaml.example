server:
  port: ":8080"

database:
  # type: "sqlite"
  # dsn: "prober.db"
  type: "postgres"
  host: "localhost"
  port: 5432
  user: "postgres"
  password: "password"
  dbname: "prp"
  sslmode: "disable"

auth:
  secret_key: "your_secret_key_here"
  jwt_algorithm: "HS256"
  jwt_expiration: "30m"             # access token lifetime, e.g. "30m", "2h"
  refresh_token_expiration: "168h"  # refresh token lifetime (default 7 days)
  bcrypt_cost: 10                   # bcrypt hashing cost (4-31)
  upload_token_length: 16           # bytes; hex output is 2x this value
  username_pattern: "^[a-z][a-z0-9_]{5,15}$"

pagination:
  default_page_size: 50
  max_page_size: 200

game:
  b35_limit: 35
  b15_limit: 15

logging:
  output: "stdout"          # stdout | stderr | file
  file: ""                  # required when output == "file", e.g. "logs/server.log"
  format: "text"            # text | json
  exclude_paths:            # request paths starting with any of these prefixes are not logged
    - "/healthz"

metrics:
  enabled: true             # expose Prometheus metrics on a dedicated HTTP server
  addr: ":2112"             # listen address (MUST differ from server.port)
  path: "/metrics"          # scrape path (default Prometheus convention)
  exclude_paths:            # Gin route templates starting with any of these prefixes are not counted
    - "/healthz"
