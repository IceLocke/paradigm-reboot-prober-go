server:
  port: ":8080"

database:
  # type: "sqlite"
  # dsn: "prober.db"
  type: "postgres"
  host: "localhost"
  port: 5432
  user: "postgres"
  password: "password"
  dbname: "prp"
  sslmode: "disable"

auth:
  secret_key: "your_secret_key_here"
  jwt_algorithm: "HS256"
  jwt_expiration: "30m"             # access token lifetime, e.g. "30m", "2h"
  refresh_token_expiration: "168h"  # refresh token lifetime (default 7 days)
  bcrypt_cost: 10                   # bcrypt hashing cost (4-31)
  upload_token_length: 16           # bytes; hex output is 2x this value
  username_pattern: "^[a-z][a-z0-9_]{5,15}$"

pagination:
  default_page_size: 50
  max_page_size: 200

game:
  b35_limit: 35
  b15_limit: 15

logging:
  output: "stdout"          # stdout | stderr | file
  file: ""                  # required when output == "file", e.g. "logs/server.log"
  format: "text"            # text | json
  exclude_paths:            # request paths starting with any of these prefixes are not logged
    - "/healthz"

metrics:
  enabled: true             # expose Prometheus metrics on a dedicated HTTP server
  addr: ":9090"             # listen address (MUST differ from server.port)
  path: "/metrics"          # scrape path (default Prometheus convention)
  exclude_paths:            # Gin route templates starting with any of these prefixes are not counted
    - "/healthz"

# Fitting-level calculator microservice (cmd/fitting). This is a separate binary that
# runs offline on a periodic schedule. The main cmd/server process does NOT read these
# values at runtime; keeping the probe service decoupled from fitting is an explicit
# design principle (see AGENTS.md → “保持查分器本体的单纯性”).
fitting:
  enabled: true             # master switch for the fitting-calculator microservice
  interval: "6h"            # run every interval (Go duration string, e.g. "6h", "30m")
  min_samples: 8.0          # minimum effective sample size to publish fitting_level
  min_player_records: 20    # player needs ≥ this many best records to contribute
  proximity_sigma: 20.0     # Gaussian σ in rating units (centered on 10×Level)
  high_skill_sigma_ratio: 0.3 # σ multiplier for skill > 10×Level (over-skill side); 1.0 = symmetric, smaller = stronger discount on over-skilled players
  volume_full_at: 50        # a player at this record count receives full volume weight
  prior_strength: 5.0       # κ in Bayesian shrinkage toward the official level
  deviation_penalty: 2.0    # λ; scales extra prior weight with dev² and sample sparsity (0 disables)
  max_deviation: 1.5         # hard cap on |fitting_level − level| at or above max_deviation_high_at
  max_deviation_low: 0.6     # cap at or below max_deviation_low_at; ≤0 disables the ramp (falls back to flat max_deviation)
  max_deviation_low_at: 12.0 # level at which cap = max_deviation_low (e.g. 12)
  max_deviation_high_at: 17.0 # level at which cap = max_deviation (e.g. 17); log-interpolated between endpoints
  min_score: 500000         # discard samples below this score threshold
  tukey_k: 4.685            # Tukey biweight tuning constant (outlier trimming)
  chart_batch_size: 200     # charts per DB batch (keep DB load bounded)
  player_batch_size: 500    # users fetched per page during skill collection
  batch_pause: "50ms"       # sleep between chart batches to ease DB load
