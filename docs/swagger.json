{
    "schemes": [
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "This is the API documentation for the Paradigm: Reboot Prober service.",
        "title": "Paradigm: Reboot Prober API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
