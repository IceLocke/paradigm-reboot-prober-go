        "model.Difficulty": {
            "type": "string",
            "enum": [
                "detected",
                "invaded",
                "massive",
                "reboot"
            ],
            "x-enum-varnames": [
                "DifficultyDetected",
                "DifficultyInvaded",
                "DifficultyMassive",
                "DifficultyReboot"
            ]
        },
